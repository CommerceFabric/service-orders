{
  "Routes": [
    // Orders microservice
    {
      "UpstreamPathTemplate": "/gateway/Orders/", // The path that clients send requests to on the API Gateway
      "DownstreamPathTemplate": "/api/Orders", // The path on the downstream Orders service that Ocelot forwards requests to

      "DownstreamScheme": "http", // The protocol Ocelot uses when connecting to the downstream service
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api", // The hostname of the downstream Orders service (e.g., a Docker Compose service name or DNS hostname)
          "Port": 8080 // The port the downstream Orders service is listening on
        }
      ],
      "UpstreamHttpMethod": [ // The HTTP methods that Ocelot will accept for this route
        "GET",
        "POST",
        "OPTIONS"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Orders/search/orderid/{orderID}/",
      "DownstreamPathTemplate": "/api/Orders/search/orderid/{orderID}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Orders/search/productid/{productID}/",
      "DownstreamPathTemplate": "/api/Orders/search/productid/{productID}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Orders/search/userid/{userID}/",
      "DownstreamPathTemplate": "/api/Orders/search/userid/{userID}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Orders/search/orderdate/{orderDate}/",
      "DownstreamPathTemplate": "/api/Orders/search/orderdate/{orderDate}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Orders/{orderID}/",
      "DownstreamPathTemplate": "/api/Orders/{orderID}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "ordersmicroservice.api",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "PUT",
        "DELETE"
      ]
    },

    // Products microservice
    {
      "UpstreamPathTemplate": "/gateway/Products/",
      "DownstreamPathTemplate": "/api/Products",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET",
        "POST",
        "PUT",
        "OPTIONS"
      ],
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3, // circuit breaker will open after 3 exceptions
        "DurationOfBreak": 10000, // circuit breaker will stay open for 10 seconds, then will go to half-open state to test if the downstream service is healthy again
        "TimeoutValue": 5000 // timeout for downstream service calls in milliseconds, so if the downstream service takes longer than 5 seconds to respond, Ocelot will consider it a failure and trigger the circuit breaker
      },
      "RetryOptions": {
        "RetryCount": 3, // number of times to retry the downstream service call if it fails
        "RetryBackOffPeriod": 2000, // time in milliseconds to wait before retrying the downstream service call
        "RetryOnServerError": true // retry on server errors (5xx status codes)
      },
      "RateLimitOptions": { // set rate limit, eg 3 requests per client per minute (as determined via ClientId header in request) - requests exceeding this limit will receive a 429 Too Many Requests response, allowing requests again after the specified period
        "Limit": 3,
        "Period": "1m",
        "HttpStatusCode": 429,
        "EnableRateLimiting": true,
        "PeriodTimespan": 30, // time in seconds for the rate limit period aka after 30 seconds the rate limit will reset and the client can make requests again
        "ClientWhitelist": [], // optionally, you can specify a list of client IDs that are exempt from rate limiting. If you want to allow all clients, leave this list empty.
        "ClientIdHeader": "ClientId" // the name of the header that clients must include in their requests to identify themselves for rate limiting purposes
      },
      "FileCacheOptions": {
        "TtlSeconds": 30, // time in seconds to cache the response from the downstream service
        "Region": ""
      } 
    },
    {
      "UpstreamPathTemplate": "/gateway/Products/search/product-id/{productId}/",
      "DownstreamPathTemplate": "/api/Products/search/product-id/{productId}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Products/search/category/{category}/",
      "DownstreamPathTemplate": "/api/Products/search/category/{category}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Products/search/{query}/",
      "DownstreamPathTemplate": "/api/Products/search/{query}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Products/{productId}/",
      "DownstreamPathTemplate": "/api/Products/{productId}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "DELETE"
      ]
    },

    // Users Microservice
    {
      "UpstreamPathTemplate": "/gateway/Users/Auth/register/",
      "DownstreamPathTemplate": "/api/Auth/register",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "POST"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Users/Auth/login/",
      "DownstreamPathTemplate": "/api/Auth/login",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "POST"
      ]
    },
    {
      "UpstreamPathTemplate": "/gateway/Users/{userID}/",
      "DownstreamPathTemplate": "/api/Users/{userID}",

      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "UpstreamHttpMethod": [
        "GET"
      ]
    }


  ],

  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:4000", // The public base URL of the API Gateway
    //"RateLimitOptions": {
    //  "ClientIdHeader": "ClientId"
    //}
  }

  /*
    Example:

    Client sends a request to:
    https://localhost:5000/gateway/Orders

    Ocelot forwards the request to:
    http://ordersmicroservice.api:8080/api/Orders
  */
}