{
  "profiles": {
    "http": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ORDERS_MONGODB_HOST": "localhost",
        "ORDERS_MONGODB_PORT": "27017",
        "USERS_MICROSERVICE_HOST": "localhost",
        "USERS_MICROSERVICE_PORT": "9090",
        "USERS_MICROSERVICE_SCHEME": "http",
        "MONGODB_DATABASE": "OrdersDb"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "http://localhost:5174",
      "launchUrl": "swagger"
    },
    "https": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ORDERS_MONGODB_HOST": "localhost",
        "ORDERS_MONGODB_PORT": "27017",
        "USERS_MICROSERVICE_HOST": "localhost",
        "USERS_MICROSERVICE_PORT": "9091",
        "USERS_MICROSERVICE_SCHEME": "https",
        "MONGODB_DATABASE": "OrdersDb"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7098;http://localhost:5174",
      "launchUrl": "swagger"
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
      "environmentVariables": {
        "ASPNETCORE_HTTPS_PORTS": "8081",
        "ASPNETCORE_HTTP_PORTS": "8080"
      },
      "publishAllPorts": true,
      "useSSL": true
    }
  },
  "$schema": "https://json.schemastore.org/launchsettings.json"
}